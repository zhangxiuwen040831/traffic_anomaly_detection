{
  "experiment": {
    "seed": 42,
    "stage": "stage4",
    "notes": "Stage 4 - Final Model Optimization, Packaging, and Deployment"
  },
  "dataset": {
    "name": "cic_ids2017",
    "raw_root": "data/raw",
    "processed_root": "data/stage4/processed",
    "cache_enabled": true,
    "force_refresh": false,
    "smoke_max_rows": 10000,
    "train_size": 0.6,
    "val_size": 0.2,
    "test_size": 0.2,
    "normal_label": 0,
    "label_column": "label",
    "label_column_candidates": [
      "label",
      "Label",
      " Label"
    ],
    "attack_column_candidates": [
      "attack_cat",
      "attack",
      "Attack",
      " Label"
    ],
    "drop_columns": [],
    "synthetic_fallback_rows": 4096,
    "random_state": 42,
    "datasets": {
      "unsw_nb15": {
        "file_patterns": [
          "UNSW_NB15_training-set.csv",
          "UNSW_NB15_testing-set.csv",
          "UNSW_NB15.csv"
        ],
        "normal_tokens": [
          "0",
          "normal",
          "benign"
        ],
        "label_column_candidates": [
          "label",
          "Label",
          " Label"
        ],
        "attack_column_candidates": [
          "attack_cat",
          "attack",
          "Attack"
        ]
      },
      "cic_ids2017": {
        "file_patterns": [
          "**/*.csv"
        ],
        "normal_tokens": [
          "BENIGN",
          "benign",
          "Normal",
          "normal"
        ],
        "label_column_candidates": [
          " Label",
          "label",
          "Label"
        ],
        "attack_column_candidates": [
          "attack_cat",
          " Label",
          "label",
          "Label"
        ]
      }
    }
  },
  "model": {
    "name": "enhanced_mlp_ae",
    "checkpoint_metric": "val_loss"
  },
  "models": {
    "enhanced_mlp_ae": {
      "type": "enhanced_mlp_ae",
      "hidden_dims": [
        128,
        64
      ],
      "latent_dim": 32,
      "activation": "relu",
      "dropout": 0.2,
      "use_batchnorm": true,
      "scoring": {
        "method": "hybrid",
        "components": [
          "reconstruction",
          "weighted_feature"
        ],
        "weights": {
          "reconstruction": 0.6,
          "weighted_feature": 0.4
        }
      }
    },
    "vae": {
      "type": "vae",
      "hidden_dims": [
        128,
        64
      ],
      "latent_dim": 16,
      "activation": "relu",
      "dropout": 0.1,
      "beta": 0.05,
      "scoring": {
        "method": "hybrid",
        "components": [
          "reconstruction",
          "latent_distance",
          "density"
        ],
        "weights": {
          "reconstruction": 0.6,
          "latent_distance": 0.3,
          "density": 0.1
        }
      }
    },
    "hybrid_ae": {
      "type": "hybrid_ae",
      "hidden_dims": [
        128,
        64
      ],
      "latent_dim": 32,
      "activation": "relu",
      "dropout": 0.2,
      "use_batchnorm": true,
      "scoring": {
        "method": "hybrid",
        "components": [
          "reconstruction",
          "latent_distance",
          "density",
          "weighted_feature"
        ],
        "weights": {
          "reconstruction": 0.4,
          "latent_distance": 0.25,
          "density": 0.15,
          "weighted_feature": 0.2
        }
      }
    }
  },
  "training": {
    "device": "auto",
    "epochs": 30,
    "batch_size": 256,
    "learning_rate": 0.001,
    "weight_decay": 1e-05,
    "optimizer": "adamw",
    "scheduler": "plateau",
    "scheduler_patience": 5,
    "scheduler_factor": 0.5,
    "early_stopping_patience": 10,
    "min_delta": 0.0001,
    "grad_clip_norm": 5.0,
    "num_workers": 0,
    "resume": false
  },
  "scoring": {
    "batch_size": 512,
    "covariance_regularization": 0.0001
  },
  "threshold": {
    "primary_method": "f1_optimal",
    "percentile": 95,
    "methods": [
      "f1_optimal",
      "youden",
      "pr_optimal"
    ]
  },
  "evaluation": {
    "positive_label": 1,
    "save_component_plots": true
  },
  "outputs": {
    "root": "outputs_stage4",
    "run_group": "final_optimization",
    "comparison_dir": "comparison",
    "ablation_dir": "ablation",
    "final_report_dir": "final_report",
    "deploy_root": "deploy_bundle",
    "frontend_root": "frontend_app"
  },
  "ablation": {
    "scoring_variants": [
      {
        "name": "reconstruction_only",
        "method": "reconstruction",
        "components": [
          "reconstruction"
        ]
      },
      {
        "name": "reconstruction_latent",
        "method": "hybrid",
        "components": [
          "reconstruction",
          "latent_distance"
        ],
        "weights": {
          "reconstruction": 0.7,
          "latent_distance": 0.3
        }
      },
      {
        "name": "reconstruction_weighted",
        "method": "hybrid",
        "components": [
          "reconstruction",
          "weighted_feature"
        ],
        "weights": {
          "reconstruction": 0.6,
          "weighted_feature": 0.4
        }
      },
      {
        "name": "hybrid_full",
        "method": "hybrid",
        "components": [
          "reconstruction",
          "latent_distance",
          "density"
        ],
        "weights": {
          "reconstruction": 0.5,
          "latent_distance": 0.3,
          "density": 0.2
        }
      }
    ]
  },
  "cloud": {},
  "_config_path": "D:\\zlx\\traffic_anomaly_detection\\config\\stage4\\base.yaml",
  "_project_root": "D:\\zlx\\traffic_anomaly_detection"
}